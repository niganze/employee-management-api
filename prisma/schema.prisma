generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {

  id        Int      @id @default(autoincrement())

  name      String

  email     String   @unique

  password  String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

}

model Employee {

  id Int @id @default(autoincrement())

  firstName String

  lastName String

  email String @unique

  phone String

  position String

  department String

  salary Float

  hireDate DateTime

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

}